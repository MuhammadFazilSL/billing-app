generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. Core Platform Entities
// ==========================================

model PlatformAdmin {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  role      String   @default("SUPER_ADMIN") @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  auditLogs PlatformAuditLog[]

  @@map("platform_admins")
}

model PlatformConfig {
  id                  String   @id @default("default") @db.VarChar(50)
  platformName        String   @default("Billing SaaS") @map("platform_name")
  logoUrl             String?  @map("logo_url")
  supportEmail        String?  @map("support_email")
  supportPhone        String?  @map("support_phone")
  timezone            String   @default("UTC")
  currency            String   @default("USD")
  registrationEnabled Boolean  @default(true) @map("registration_enabled")
  maintenanceMode     Boolean  @default(false) @map("maintenance_mode")
  defaultTrialDays    Int      @default(14) @map("default_trial_days")
  defaultPlanId       String?  @map("default_plan_id") @db.Uuid
  companyAddress      String?  @map("company_address") @db.Text
  privacyPolicyUrl    String?  @map("privacy_policy_url")
  termsConditionsUrl  String?  @map("terms_conditions_url")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  defaultPlan Plan? @relation(fields: [defaultPlanId], references: [id])

  @@map("platform_configs")
}

model PlatformAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityName String   @map("entity_name") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.VarChar(100)
  details    Json     @default("{}")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  admin PlatformAdmin @relation(fields: [adminId], references: [id])

  @@index([createdAt])
  @@map("platform_audit_logs")
}

model Plan {
  id           String  @id @default(uuid()) @db.Uuid
  name         String  @unique @db.VarChar(50)
  // Existing fields (preserved for backward compatibility)
  price        Decimal @db.Decimal(10, 2)
  billingCycle String  @db.VarChar(20)

  // New fields for Sprint 13
  code           String?  @db.VarChar(50)
  description    String?  @db.Text
  monthlyPrice   Decimal? @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice    Decimal? @map("yearly_price") @db.Decimal(10, 2)
  currency       String   @default("USD") @db.VarChar(10)
  maxCustomers   Int      @default(0) @map("max_customers")
  maxBranches    Int      @default(1) @map("max_branches")
  storageLimitMB Int      @default(100) @map("storage_limit_mb")
  trialDays      Int      @default(14) @map("trial_days")
  isActive       Boolean  @default(true) @map("is_active")

  // Feature Toggles
  inventoryEnabled   Boolean @default(true) @map("inventory_enabled")
  billingEnabled     Boolean @default(true) @map("billing_enabled")
  purchasesEnabled   Boolean @default(true) @map("purchases_enabled")
  returnsEnabled     Boolean @default(true) @map("returns_enabled")
  reportsEnabled     Boolean @default(true) @map("reports_enabled")
  offersEnabled      Boolean @default(true) @map("offers_enabled")
  couponsEnabled     Boolean @default(true) @map("coupons_enabled")
  loyaltyEnabled     Boolean @default(true) @map("loyalty_enabled")
  multiBranchEnabled Boolean @default(false) @map("multi_branch_enabled")
  apiAccessEnabled   Boolean @default(false) @map("api_access_enabled")
  prioritySupport    Boolean @default(false) @map("priority_support")
  auditLogsEnabled   Boolean @default(false) @map("audit_logs_enabled")
  backupsEnabled     Boolean @default(false) @map("backups_enabled")

  maxProducts         Int
  maxEmployees        Int
  maxInvoicesPerMonth Int
  features            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  tenants             Tenant[]
  tenantSubscriptions TenantSubscription[]
  platformConfigs     PlatformConfig[]

  @@map("plans")
}

model Tenant {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(100)
  slug                  String   @unique @db.VarChar(100)
  logoUrl               String?  @map("logo_url") @db.VarChar(255)
  address               String?  @db.Text
  phone                 String?  @db.VarChar(20)
  currency              String   @default("USD") @db.VarChar(10)
  settings              Json     @default("{}")
  status                String   @default("ACTIVE") @db.VarChar(20)
  planId                String   @map("plan_id") @db.Uuid
  subscriptionId        String?  @map("subscription_id") @db.Uuid
  subscriptionExpiresAt DateTime @map("subscription_expires_at") @db.Timestamp(6)
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  plan                Plan                      @relation(fields: [planId], references: [id], onDelete: Restrict)
  usageMetric         UsageMetric?
  subscriptions       TenantSubscription[]
  users               User[]
  roles               Role[]
  customers           Customer[]
  suppliers           Supplier[]
  products            Product[]
  invoices            Invoice[]
  subscriptionTx      SubscriptionTransaction[]
  inventoryTx         InventoryTransaction[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  categories          Category[]
  brands              Brand[]
  units               Unit[]
  taxes               Tax[]
  productImages       ProductImage[]
  invoiceItems        InvoiceItem[]
  invoicePayments     InvoicePayment[]
  purchases           Purchase[]
  purchaseItems       PurchaseItem[]
  returns             Return[]
  returnItems         ReturnItem[]
  offers              Offer[]
  coupons             Coupon[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([status])
  @@map("tenants")
}

model SubscriptionTransaction {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  amount             Decimal  @db.Decimal(10, 2)
  paymentStatus      String   @map("payment_status") @db.VarChar(20)
  paymentGateway     String   @map("payment_gateway") @db.VarChar(50)
  gatewayReference   String?  @map("gateway_reference") @db.VarChar(100)
  billingPeriodStart DateTime @map("billing_period_start") @db.Timestamp(6)
  billingPeriodEnd   DateTime @map("billing_period_end") @db.Timestamp(6)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscription_transactions")
}

model TenantSubscription {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  planId        String    @map("plan_id") @db.Uuid
  status        String    @db.VarChar(20)
  billingCycle  String    @map("billing_cycle") @db.VarChar(20)
  startsAt      DateTime  @map("starts_at") @db.Timestamp(6)
  expiresAt     DateTime  @map("expires_at") @db.Timestamp(6)
  nextRenewalAt DateTime? @map("next_renewal_at") @db.Timestamp(6)
  autoRenew     Boolean   @default(true) @map("auto_renew")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("tenant_subscriptions")
}

model UsageMetric {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @unique @map("tenant_id") @db.Uuid
  productsUsed      Int      @default(0) @map("products_used")
  employeesUsed     Int      @default(0) @map("employees_used")
  customersUsed     Int      @default(0) @map("customers_used")
  invoicesThisMonth Int      @default(0) @map("invoices_this_month")
  storageUsedMB     Decimal  @default(0.00) @map("storage_used_mb") @db.Decimal(10, 2)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("usage_metrics")
}

// ==========================================
// 2. User & Access Control (RBAC)
// ==========================================

model User {
  id                 String                 @id @default(uuid()) @db.Uuid
  email              String                 @unique @db.VarChar(100)
  passwordHash       String                 @map("password_hash") @db.VarChar(255)
  firstName          String                 @map("first_name") @db.VarChar(50)
  lastName           String                 @map("last_name") @db.VarChar(50)
  phone              String?                @db.VarChar(20)
  tenantId           String?                @map("tenant_id") @db.Uuid
  status             String                 @default("ACTIVE") @db.VarChar(20)
  isMasterAdmin      Boolean                @default(false) @map("is_master_admin")
  employeeCode       String?                @map("employee_code") @db.VarChar(50)
  designation        String?                @db.VarChar(100)
  joiningDate        DateTime?              @map("joining_date") @db.Date
  salary             Decimal?               @db.Decimal(10, 2)
  notes              String?                @db.Text
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt          DateTime?              @map("deleted_at") @db.Timestamp(6)
  hashedRefreshToken String?                @map("hashed_refresh_token") @db.VarChar(255)
  tenant             Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles          UserRole[]
  invoices           Invoice[]
  inventoryTx        InventoryTransaction[]
  activityLogs       ActivityLog[]
  createdProducts    Product[]              @relation("ProductCreatedBy")
  updatedProducts    Product[]              @relation("ProductUpdatedBy")
  purchases          Purchase[]
  returns            Return[]

  @@index([tenantId])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  name            String           @db.VarChar(50)
  description     String?          @db.Text
  isSystemRole    Boolean          @default(false) @map("is_system_role")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamp(6)
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique @db.VarChar(50)
  description     String           @db.VarChar(255)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// ==========================================
// 3. CRM & Supplier Relations (CRM/SRM)
// ==========================================

model Customer {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  name                String               @db.VarChar(100)
  email               String?              @db.VarChar(100)
  phone               String?              @db.VarChar(20)
  address             String?              @db.Text
  outstandingBalance  Decimal              @default(0.00) @map("outstanding_balance") @db.Decimal(12, 2)
  creditLimit         Decimal?             @map("credit_limit") @db.Decimal(12, 2)
  loyaltyPoints       Int                  @default(0) @map("loyalty_points")
  lastPurchaseDate    DateTime?            @map("last_purchase_date") @db.Timestamp(6)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamp(6)
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices            Invoice[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([tenantId, phone])
  @@map("customers")
}

model Supplier {
  id                 String     @id @default(uuid()) @db.Uuid
  tenantId           String     @map("tenant_id") @db.Uuid
  companyName        String     @map("company_name") @db.VarChar(100)
  contactName        String?    @map("contact_name") @db.VarChar(100)
  email              String?    @db.VarChar(100)
  phone              String?    @db.VarChar(20)
  address            String?    @db.Text
  outstandingBalance Decimal    @default(0.00) @map("outstanding_balance") @db.Decimal(12, 2)
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt          DateTime?  @map("deleted_at") @db.Timestamp(6)
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases          Purchase[]

  @@index([tenantId])
  @@map("suppliers")
}

// ==========================================
// 4. Product Catalog & Inventory
// ==========================================

model Product {
  id            String                 @id @default(uuid()) @db.Uuid
  tenantId      String                 @map("tenant_id") @db.Uuid
  name          String                 @db.VarChar(150)
  sku           String?                @db.VarChar(50)
  barcode       String?                @db.VarChar(50)
  qrCode        String?                @map("qr_code") @db.VarChar(255)
  description   String?                @db.Text
  purchasePrice Decimal                @map("purchase_price") @db.Decimal(10, 2)
  sellingPrice  Decimal                @map("selling_price") @db.Decimal(10, 2)
  mrp           Decimal?               @db.Decimal(10, 2)
  stock         Decimal                @default(0.000) @db.Decimal(12, 3)
  minimumStock  Decimal                @default(5.000) @map("minimum_stock") @db.Decimal(12, 3)
  reorderLevel  Decimal                @default(10.000) @map("reorder_level") @db.Decimal(12, 3)
  categoryId    String?                @map("category_id") @db.Uuid
  brandId       String?                @map("brand_id") @db.Uuid
  unitId        String?                @map("unit_id") @db.Uuid
  taxId         String?                @map("tax_id") @db.Uuid
  status        String                 @default("ACTIVE") @db.VarChar(20)
  createdById   String?                @map("created_by_id") @db.Uuid
  updatedById   String?                @map("updated_by_id") @db.Uuid
  createdAt     DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt     DateTime?              @map("deleted_at") @db.Timestamp(6)
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  brand         Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit          Unit?                  @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tax           Tax?                   @relation(fields: [taxId], references: [id], onDelete: Restrict)
  createdBy     User?                  @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?                  @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  images        ProductImage[]
  inventoryTx   InventoryTransaction[]
  invoiceItems  InvoiceItem[]
  purchaseItems PurchaseItem[]
  returnItems   ReturnItem[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, stock])
  @@map("products")
}

model InventoryTransaction {
  id                      String   @id @default(uuid()) @db.Uuid
  tenantId                String   @map("tenant_id") @db.Uuid
  productId               String   @map("product_id") @db.Uuid
  type                    String   @db.VarChar(30)
  quantity                Decimal  @db.Decimal(12, 3)
  balanceAfterTransaction Decimal  @map("balance_after_transaction") @db.Decimal(12, 3)
  direction               String   @db.VarChar(5)
  unitCost                Decimal  @map("unit_cost") @db.Decimal(10, 2)
  referenceType           String?  @map("reference_type") @db.VarChar(50)
  referenceId             String?  @map("reference_id") @db.Uuid
  userId                  String   @map("user_id") @db.Uuid
  remarks                 String?  @db.Text
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product                 Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, productId, createdAt])
  @@map("inventory_transactions")
}

model Category {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String     @map("tenant_id") @db.Uuid
  parentCategoryId String?    @map("parent_category_id") @db.Uuid
  name             String     @db.VarChar(100)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt        DateTime?  @map("deleted_at") @db.Timestamp(6)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentCategory   Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Restrict)
  subCategories    Category[] @relation("CategoryHierarchy")
  products         Product[]

  @@map("categories")
}

model Brand {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@map("brands")
}

model Unit {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(50)
  shortName String    @map("short_name") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamp(6)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@map("units")
}

model Tax {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(50)
  rate        Decimal   @db.Decimal(5, 2)
  isInclusive Boolean   @default(false) @map("is_inclusive")
  isDefault   Boolean   @default(false) @map("is_default")
  status      String    @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamp(6)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@map("taxes")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String   @db.VarChar(255)
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ==========================================
// 5. Billing & Sales Invoices
// ==========================================

model Invoice {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String               @map("tenant_id") @db.Uuid
  invoiceNumber       String               @map("invoice_number") @db.VarChar(50)
  customerId          String?              @map("customer_id") @db.Uuid
  subTotal            Decimal              @map("sub_total") @db.Decimal(12, 2)
  discountAmount      Decimal              @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount           Decimal              @map("tax_amount") @db.Decimal(12, 2)
  grandTotal          Decimal              @map("grand_total") @db.Decimal(12, 2)
  amountPaid          Decimal              @map("amount_paid") @db.Decimal(12, 2)
  balanceDue          Decimal              @map("balance_due") @db.Decimal(12, 2)
  paymentStatus       String               @map("payment_status") @db.VarChar(20)
  paymentMethod       String               @map("payment_method") @db.VarChar(20)
  status              String               @default("COMPLETED") @db.VarChar(20)
  userId              String               @map("user_id") @db.Uuid
  notes               String?              @db.Text
  couponCode          String?              @map("coupon_code") @db.VarChar(50)
  loyaltyRedeemed     Int?                 @default(0) @map("loyalty_redeemed")
  discountDetails     Json?                @map("discount_details")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt           DateTime?            @map("deleted_at") @db.Timestamp(6)
  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer            Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user                User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  invoiceItems        InvoiceItem[]
  payments            InvoicePayment[]
  returns             Return[]
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  invoiceId      String  @map("invoice_id") @db.Uuid
  productId      String  @map("product_id") @db.Uuid
  productName    String  @map("product_name") @db.VarChar(150)
  quantity       Decimal @db.Decimal(12, 3)
  unitPrice      Decimal @map("unit_price") @db.Decimal(10, 2)
  unitCost       Decimal @map("unit_cost") @db.Decimal(10, 2)
  taxRate        Decimal @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal @map("tax_amount") @db.Decimal(10, 2)
  discountAmount Decimal @default(0.00) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount    Decimal @map("total_amount") @db.Decimal(12, 2)
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice        Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoicePayment {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  invoiceId            String   @map("invoice_id") @db.Uuid
  paymentMethod        String   @map("payment_method") @db.VarChar(20)
  amount               Decimal  @db.Decimal(10, 2)
  transactionReference String?  @map("transaction_reference") @db.VarChar(100)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice              Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_payments")
}

// ==========================================
// 6. Audits, Alerts & System Logs
// ==========================================

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityName String   @map("entity_name") @db.VarChar(100)
  entityId   String   @map("entity_id") @db.Uuid
  details    Json     @default("{}")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  type      String   @db.VarChar(30)
  title     String   @db.VarChar(150)
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isRead])
  @@map("notifications")
}

// ==========================================
// 7. Purchases & Returns
// ==========================================

model Purchase {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  purchaseNumber String         @map("purchase_number") @db.VarChar(50)
  supplierId     String?        @map("supplier_id") @db.Uuid
  subTotal       Decimal        @map("sub_total") @db.Decimal(12, 2)
  taxAmount      Decimal        @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal        @default(0.00) @map("discount_amount") @db.Decimal(12, 2)
  grandTotal     Decimal        @map("grand_total") @db.Decimal(12, 2)
  amountPaid     Decimal        @map("amount_paid") @db.Decimal(12, 2)
  balanceDue     Decimal        @map("balance_due") @db.Decimal(12, 2)
  paymentStatus  String         @map("payment_status") @db.VarChar(20)
  paymentMethod  String         @map("payment_method") @db.VarChar(20)
  status         String         @default("COMPLETED") @db.VarChar(20)
  userId         String         @map("user_id") @db.Uuid
  notes          String?        @db.Text
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt      DateTime?      @map("deleted_at") @db.Timestamp(6)
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  user           User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  purchaseItems  PurchaseItem[]
  returns        Return[]

  @@unique([tenantId, purchaseNumber])
  @@index([tenantId, createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  purchaseId     String   @map("purchase_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  productName    String   @map("product_name") @db.VarChar(150)
  quantity       Decimal  @db.Decimal(12, 3)
  unitCost       Decimal  @map("unit_cost") @db.Decimal(10, 2)
  taxRate        Decimal  @map("tax_rate") @db.Decimal(5, 2)
  taxAmount      Decimal  @map("tax_amount") @db.Decimal(10, 2)
  discountAmount Decimal  @default(0.00) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(12, 2)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchase       Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@map("purchase_items")
}

model Return {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  returnNumber String       @map("return_number") @db.VarChar(50)
  returnType   String       @map("return_type") @db.VarChar(30) // SALES_RETURN, PURCHASE_RETURN
  invoiceId    String?      @map("invoice_id") @db.Uuid
  purchaseId   String?      @map("purchase_id") @db.Uuid
  subTotal     Decimal      @map("sub_total") @db.Decimal(12, 2)
  taxAmount    Decimal      @map("tax_amount") @db.Decimal(12, 2)
  grandTotal   Decimal      @map("grand_total") @db.Decimal(12, 2)
  status       String       @default("COMPLETED") @db.VarChar(20)
  userId       String       @map("user_id") @db.Uuid
  notes        String?      @db.Text
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp(6)
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamp(6)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchase     Purchase?    @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  returnItems  ReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId, createdAt])
  @@map("returns")
}

model ReturnItem {
  id              String  @id @default(uuid()) @db.Uuid
  tenantId        String  @map("tenant_id") @db.Uuid
  returnId        String  @map("return_id") @db.Uuid
  productId       String  @map("product_id") @db.Uuid
  productName     String  @map("product_name") @db.VarChar(150)
  quantity        Decimal @db.Decimal(12, 3)
  unitPriceOrCost Decimal @map("unit_price_or_cost") @db.Decimal(10, 2)
  totalAmount     Decimal @map("total_amount") @db.Decimal(12, 2)
  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  returnRecord    Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([returnId])
  @@map("return_items")
}

model Offer {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  name                  String    @db.VarChar(100)
  type                  String    @db.VarChar(20) // PERCENTAGE, FLAT
  value                 Decimal   @db.Decimal(10, 2)
  isActive              Boolean   @default(true) @map("is_active")
  validFrom             DateTime? @map("valid_from") @db.Timestamp(6)
  validTo               DateTime? @map("valid_to") @db.Timestamp(6)
  applicableProductIds  Json?     @map("applicable_product_ids") // Array of product IDs
  applicableCategoryIds Json?     @map("applicable_category_ids") // Array of category IDs
  offerScope            String    @map("offer_scope") @db.VarChar(50) // PRODUCT, CATEGORY, STORE
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamp(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("offers")
}

model Coupon {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  code               String    @unique @db.VarChar(50)
  type               String    @db.VarChar(20) // PERCENTAGE, FLAT
  value              Decimal   @db.Decimal(10, 2)
  minPurchaseAmount  Decimal?  @map("min_purchase_amount") @db.Decimal(10, 2)
  maxDiscount        Decimal?  @map("max_discount") @db.Decimal(10, 2)
  maxUses            Int?      @map("max_uses")
  maxUsesPerCustomer Int?      @map("max_uses_per_customer")
  currentUses        Int       @default(0) @map("current_uses")
  isActive           Boolean   @default(true) @map("is_active")
  validFrom          DateTime? @map("valid_from") @db.Timestamp(6)
  validTo            DateTime? @map("valid_to") @db.Timestamp(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamp(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("coupons")
}

model LoyaltyTransaction {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  invoiceId  String?  @map("invoice_id") @db.Uuid
  type       String   @db.VarChar(50) // EARN, REDEEM, EXPIRE, ADJUSTMENT
  points     Int
  remarks    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoice  Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, customerId])
  @@map("loyalty_transactions")
}
