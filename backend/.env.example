# Application Environment Parameters
PORT=3000
NODE_ENV=development

# Database Connection Settings (PostgreSQL - Supabase)
# Connect to PostgreSQL with connection pooling (PgBouncer) via Transaction Mode
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres?pgbouncer=true"
# Connect to PostgreSQL directly for migrations (Session Mode)
DIRECT_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"

# JWT Secrets for Cryptographic Signings
JWT_SECRET="generate-a-secure-random-access-token-secret-here"
JWT_REFRESH_SECRET="generate-a-secure-random-refresh-token-secret-here"
